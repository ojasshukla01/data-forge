# Data Forge environment variables
# Copy to .env and adjust as needed. Never commit .env.

# Paths (relative to project root)
# DATA_FORGE_PROJECT_ROOT=.
# DATA_FORGE_OUTPUT_DIR=output
# DATA_FORGE_SCHEMAS_DIR=schemas
# DATA_FORGE_RULES_DIR=rules

# Generation defaults
# DATA_FORGE_DEFAULT_SEED=42
# DATA_FORGE_DEFAULT_SCALE=1000
# DATA_FORGE_LOCALE=en_US

# Storage backend: "file" or "sqlite"
# DATA_FORGE_STORAGE_BACKEND=file
# DATA_FORGE_SQLITE_URI=data/data_forge.db

# Run retention
# DATA_FORGE_RUNS_RETENTION_COUNT=100

# Snowflake (optional)
# DATA_FORGE_SNOWFLAKE_ACCOUNT=
# DATA_FORGE_SNOWFLAKE_USER=
# DATA_FORGE_SNOWFLAKE_PASSWORD=
# DATA_FORGE_SNOWFLAKE_WAREHOUSE=
# DATA_FORGE_SNOWFLAKE_DATABASE=
# DATA_FORGE_SNOWFLAKE_SCHEMA=PUBLIC

# BigQuery (optional)
# DATA_FORGE_BIGQUERY_PROJECT=
# DATA_FORGE_BIGQUERY_DATASET=
